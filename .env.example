# .env.local — Copy this to .env.local and fill in your values
# NEVER commit this file to GitHub

# ─── DATABASE ────────────────────────────────────────────────────────
# Get this from Supabase → Project → Settings → Database → Connection string (URI)
# Replace [YOUR-PASSWORD] with your Supabase password
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ─── ADMIN ───────────────────────────────────────────────────────────
# Your admin panel password (change this!)
ADMIN_PASSWORD="your-secure-admin-password-here"

# Random secret for JWT tokens — generate with: openssl rand -base64 32
JWT_SECRET="your-random-jwt-secret-here"

# ─── APP ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
